CREATE TABLE users (id uuid PRIMARY KEY, email text, created_at timestamptz DEFAULT now()); CREATE TABLE events (id uuid PRIMARY KEY, user_id uuid REFERENCES users(id), title text, description text, hebrew_date date, gregorian_date date, event_type text, created_at timestamptz DEFAULT now()); CREATE TABLE community_events (id uuid PRIMARY KEY, submitted_by uuid REFERENCES users(id), title text, description text, hebrew_date date, votes integer DEFAULT 0, approved boolean DEFAULT false, created_at timestamptz DEFAULT now());